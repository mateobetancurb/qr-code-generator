{
	"name": "qr-code-generator",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro check && astro build",
		"lint": "oxlint .",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"preview": "astro preview",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"check": "pnpm format:check && pnpm lint && pnpm test:coverage && pnpm build"
	},
	"dependencies": {
		"@fontsource-variable/geist": "^5.2.9",
		"@phosphor-icons/web": "^2.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"qrcode": "^1.5.4",
		"tailwindcss": "^4.3.1"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@testing-library/jest-dom": "^6.9.1",
		"@types/qrcode": "^1.5.6",
		"@vitest/coverage-v8": "^4.1.9",
		"astro": "^6.4.8",
		"jsdom": "^29.1.1",
		"oxfmt": "^0.55.0",
		"oxlint": "^1.70.0",
		"typescript": "~6.0.3",
		"vite": "^7.3.5",
		"vitest": "^4.1.9"
	},
	"packageManager": "pnpm@11.8.0"
}

---
const iconNames = {
	check: "check-circle",
	chevron: "caret-down",
	download: "download-simple",
	image: "image-square",
	link: "link-simple",
	moon: "moon",
	palette: "palette",
	qr: "qr-code",
	remove: "x",
	shapes: "shapes",
	shield: "shield-check",
	sun: "sun",
} as const;

interface Props {
	name: keyof typeof iconNames;
	class?: string;
}

const { name, class: className = "" } = Astro.props;
---

<i class:list={["ph", `ph-${iconNames[name]}`, className]} aria-hidden="true"></i>

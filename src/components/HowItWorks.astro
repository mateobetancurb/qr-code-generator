---
import type { Translation } from "../i18n/types";
import Icon from "./Icon.astro";

interface Props { t: Translation }
const { t } = Astro.props;
const icons = ["text-cursor", "palette", "download"] as const;
---

<section id="how-it-works" class="py-20 bg-gray-50 dark:bg-gray-800">
	<div class="container mx-auto px-4">
		<div class="text-center mb-14"><h2 class="text-4xl md:text-5xl font-bold text-gray-800 dark:text-white mb-4">{t.howItWorks.heading}</h2><p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">{t.howItWorks.subheading}</p></div>
		<ol class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
			{t.howItWorks.steps.map((step, index) => (
				<li class="bg-white dark:bg-gray-900 rounded-2xl p-8 shadow-lg">
					<div class="flex items-center justify-between mb-6"><div class="w-14 h-14 rounded-2xl bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center"><Icon name={icons[index]} class="w-7 h-7 text-blue-600 dark:text-blue-300" /></div><span class="text-4xl font-bold text-blue-100 dark:text-gray-700">{index + 1}</span></div>
					<h3 class="text-xl font-semibold text-gray-800 dark:text-white mb-3">{step.title}</h3><p class="text-gray-600 dark:text-gray-300 leading-relaxed">{step.description}</p>
				</li>
			))}
		</ol>
	</div>
</section>

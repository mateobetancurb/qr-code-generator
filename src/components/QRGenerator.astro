---
import type { Translation } from "../i18n/types";
import Icon from "./Icon.astro";

interface Props { t: Translation }
const { t } = Astro.props;
---

<section id="generator" data-qr-generator class="workspace-section">
	<div class="page-container">
		<div class="workspace-heading">
			<p class="workspace-kicker">{t.generator.kicker}</p>
			<h1>{t.generator.title}</h1>
			<p>{t.generator.subtitle}</p>
		</div>

		<div class="workspace-grid">
			<div class="content-panel panel">
				<div class="panel-heading">
					<span class="section-icon"><Icon name="link" /></span>
					<div><h2>{t.generator.content}</h2><p>{t.generator.contentHint}</p></div>
				</div>
				<label for="text">{t.generator.textOrUrl}</label>
				<textarea id="text" data-qr-text rows="5" placeholder={t.generator.placeholder}></textarea>
			</div>

			<div class="preview-column">
				<div class="preview-panel panel">
					<div class="preview-heading"><h2>{t.generator.preview}</h2><span class="live-indicator">{t.generator.livePreview}</span></div>
					<div class="preview-stage">
						<canvas data-qr-canvas role="img" aria-label={t.generator.previewLabel} hidden></canvas>
						<div data-empty-preview class="empty-preview">
							<span class="empty-preview-icon"><Icon name="qr" /></span>
							<span>{t.generator.emptyPreview}</span>
						</div>
					</div>
					<p data-qr-status class="sr-only" role="status" aria-live="polite" data-empty={t.generator.emptyPreview} data-ready={t.generator.previewReady}>{t.generator.emptyPreview}</p>
					<p data-qr-error role="alert" class="error-message" hidden>{t.generator.generationError}</p>
					<div data-downloads class="download-actions" hidden>
						<button data-download="png" type="button" class="button button-primary"><Icon name="download" />{t.generator.downloadPng}</button>
						<button data-download="svg" type="button" class="button button-secondary"><Icon name="download" />{t.generator.downloadSvg}</button>
					</div>
				</div>
			</div>

			<details data-customization class="customization-panel panel">
				<summary>
					<span><span class="section-icon"><Icon name="palette" /></span><span><strong>{t.generator.customize}</strong><small>{t.generator.customizeHint}</small></span></span>
					<Icon name="chevron" class="disclosure-icon" />
				</summary>
				<div class="customization-content">
					<div class="control-group">
						<label for="qr-size">{t.generator.size}</label>
						<select id="qr-size" data-qr-size>
							<option value="small">{t.generator.sizeSmall}</option>
							<option value="medium" selected>{t.generator.sizeMedium}</option>
							<option value="large">{t.generator.sizeLarge}</option>
							<option value="xlarge">{t.generator.sizeXlarge}</option>
						</select>
					</div>

					<fieldset class="control-group">
						<legend>{t.generator.pattern}</legend>
						<div class="segmented-control">
							<button data-module-style="square" type="button" aria-pressed="true" class="qr-pattern is-selected"><span aria-hidden="true" class="pattern-square"></span>{t.generator.patternSquare}</button>
							<button data-module-style="dots" type="button" aria-pressed="false" class="qr-pattern"><span aria-hidden="true" class="pattern-dots"></span>{t.generator.patternDots}</button>
						</div>
					</fieldset>

					<fieldset class="control-group">
						<legend>{t.generator.colors}</legend>
						<div class="color-grid">
							<div class="color-control">
								<label for="foreground">{t.generator.foreground}</label>
								<div class="color-input-row"><input id="foreground" data-color-picker="foreground" aria-label={t.generator.foreground} type="color" value="#000000" /><input data-color-text="foreground" type="text" aria-label={t.generator.foregroundHex} spellcheck="false" value="#000000" /></div>
							</div>
							<div class="color-control">
								<label for="background">{t.generator.background}</label>
								<div class="color-input-row"><input id="background" data-color-picker="background" aria-label={t.generator.background} type="color" value="#ffffff" /><input data-color-text="background" type="text" aria-label={t.generator.backgroundHex} spellcheck="false" value="#ffffff" /></div>
							</div>
						</div>
					</fieldset>
				</div>
			</details>
		</div>

		<ul class="trust-strip" aria-label={t.trust.label}>
			{t.trust.items.map((item) => <li><Icon name={item.icon} /><span><strong>{item.title}</strong><small>{item.description}</small></span></li>)}
		</ul>
	</div>
</section>

<script>
	import { initQRGenerator } from "../scripts/qrGenerator";
	initQRGenerator();
	document.addEventListener("astro:page-load", initQRGenerator);
</script>

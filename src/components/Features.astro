---
import type { Translation } from "../i18n/types";
import { featureCardConfig } from "../utils";
import Icon from "./Icon.astro";

interface Props { t: Translation }
const { t } = Astro.props;
const features = featureCardConfig.map((config) => ({ ...config, ...t.features.cards.find((card) => card.id === config.id) }));
---

<section id="features" class="py-20 bg-white dark:bg-gray-900 transition-colors duration-300">
	<div class="container mx-auto px-4">
		<div class="text-center mb-16">
			<h2 class="text-4xl md:text-5xl font-bold text-gray-800 dark:text-white mb-4">{t.features.heading}</h2>
			<p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">{t.features.subheading}</p>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{features.map((feature, index) => (
				<div class="group bg-gray-50 dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transform hover:-translate-y-2 transition-all duration-300 border border-gray-100 dark:border-gray-700 animate-slide-up" style={`animation-delay: ${index * 100}ms`}>
					<div class:list={["w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-200", feature.bgColor]}><Icon name={feature.icon} class:list={["w-8 h-8", feature.color]} /></div>
					<h3 class="text-xl font-semibold text-gray-800 dark:text-white mb-4">{feature.title}</h3>
					<p class="text-gray-600 dark:text-gray-300 leading-relaxed">{feature.description}</p>
				</div>
			))}
		</div>
		<div class="mt-20 bg-gradient-to-r from-blue-600 to-blue-700 rounded-3xl p-12 text-center">
			<h3 class="text-3xl md:text-4xl font-bold text-white mb-8">{t.features.highlightsTitle}</h3>
			<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
				{t.features.highlights.map((highlight) => <div class="text-center"><div class="text-4xl font-bold text-white mb-2">{highlight.value}</div><div class="text-white">{highlight.label}</div></div>)}
			</div>
		</div>
	</div>
</section>

---
import { localePath } from "../i18n/localeRouting";
import type { Locale, Translation } from "../i18n/types";
import Icon from "./Icon.astro";

interface Props {
	locale: Locale;
	t: Translation;
}

const { locale, t } = Astro.props;
const languageClass = (language: Locale) =>
	`language-link ${locale === language ? "language-link-active" : ""}`;
---

<header class="site-header">
	<div class="page-container header-inner">
		<a href={locale === "es" ? "/es/" : "/"} class="brand" aria-label={t.header.home}>
			<span class="brand-mark"><Icon name="qr" /></span>
			<span>QRGenerator</span>
		</a>
		<div class="header-actions">
			<div class="language-switcher" role="group" aria-label={t.header.language}>
				<a data-language-link href={localePath.en} class={languageClass("en")} lang="en" aria-current={locale === "en" ? "page" : undefined}>EN</a>
				<a data-language-link href={localePath.es} class={languageClass("es")} lang="es" aria-current={locale === "es" ? "page" : undefined}>ES</a>
			</div>
			<button data-theme-toggle type="button" aria-label={t.header.switchToDark} data-dark-label={t.header.switchToDark} data-light-label={t.header.switchToLight} class="icon-button">
				<Icon name="moon" class="theme-moon" />
				<Icon name="sun" class="theme-sun hidden" />
			</button>
		</div>
	</div>
</header>

<script>
	import { initLanguageNavigation } from "../scripts/languageNavigation";
	import { initTheme } from "../scripts/theme";
	initLanguageNavigation();
	initTheme();
	document.addEventListener("astro:page-load", initTheme);
</script>
